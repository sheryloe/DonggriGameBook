    {
      "npc_id": "npc_baek_dohyeong",
      "name_ko": "백도형",
      "first_chapter": "CH02",
      "role": "위조 검역패스 유통자 / 낙원회 완장장수",
      "faction": "낙원회",
      "tone_keywords": [
        "유창함",
        "얄팍한 카리스마",
        "비겁함"
      ],
      "sample_lines": [
        "문서가 있어야 문이 열립니다. 세상은 끝났어도 절차는 남아요.",
