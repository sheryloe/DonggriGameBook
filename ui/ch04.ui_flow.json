{   "version": "1.0.0",   "game_id": "dokdo_arc_webgame",   "chapter_id": "CH04",   "title": "상자들의 도시 UI 플로우",   "entry_screen_id": "CH04_BRIEF",   "screens": [     {       "screen_id": "CH04_BRIEF",       "screen_type": "chapter_briefing",       "title": "물류벨트 브리핑",       "purpose": "배지 확보와 판교 진입 목표를 설명한다.",       "widgets": [         "objective_panel",         "route_compare",         "line_status"       ],       "data_sources": [         "chapter_meta",         "player_inventory"       ],       "primary_actions": [         "start_mission"       ],       "notes": []     },     {       "screen_id": "CH04_MAP",       "screen_type": "world_map",       "title": "물류벨트 지도",       "purpose": "철도선과 배송터널을 한 화면에서 비교한다.",       "widgets": [         "node_map",         "route_compare",         "line_status",         "hazard_overlay"       ],       "data_sources": [         "ch04.nodes",         "route_state",         "player_stats"       ],       "primary_actions": [         "select_node",         "toggle_route_overlay",         "open_inventory"       ],       "notes": []     },     {       "screen_id": "CH04_EVENT",       "screen_type": "event_dialogue",       "title": "물류 이벤트",       "purpose": "라인 재가동, 약품 배분, 보안실 침투를 처리한다.",       "widgets": [         "event_card",         "choice_list",         "npc_portrait"       ],       "data_sources": [         "ch04.events",         "player_flags",         "reputation_state"       ],       "primary_actions": [         "pick_choice",         "back_to_map"       ],       "notes": []     },     {       "screen_id": "CH04_SECURITY",       "screen_type": "event_dialogue",       "title": "배지 인증 UI",       "purpose": "원본 회수/위조 출력 선택을 시각화한다.",       "widgets": [         "card_auth_state",         "choice_list",         "loot_preview"       ],       "data_sources": [         "ch04.events",         "player_items"       ],       "primary_actions": [         "forge_badge",         "take_original",         "cancel"       ],       "notes": []    