    },
    {
      "screen_id": "CH01_COMBAT",
      "screen_type": "combat_arena",
      "title": "스튜디오 전투",
      "purpose": "실시간/턴제 전투 UI 본체.",
      "widgets": [
        "combat_hud",
        "boss_hp",
        "noise_meter",
        "filter_meter"
      ],
      "data_sources": [
        "combat_state",
        "player_stats",
        "enemy_state"
      ],
      "primary_actions": [
        "attack",
        "skill",
        "item",
        "move"
      ],
      "notes": [
        "튜토리얼용 툴팁을 1회만 노출"
      ]
    },
    {
      "screen_id": "CH01_RESULT",
      "screen_type": "result_summary",
      "title": "결과 정산",
      "purpose": "선택 결과와 획득 플래그를 보여준다.",
      "widgets": [
        "chapter_result",
        "trust_summary",
        "loot_summary"
      ],
      "data_sources": [
        "chapter_outcome",
        "player_stats",
        "trust_state"
      ],
      "primary_actions": [
        "confirm"
      ],
      "notes": [
        "다음 챕터 버튼은 CH02 해금 후 활성"
      ]
    }
  ],
  "transitions": [
    {
      "from_screen_id": "CH01_BRIEF",
      "to_screen_id": "CH01_MAP",
      "trigger": "start_mission",
      "conditions": [],
      "notes": "브리핑 종료 후 지도 진입"
    },
    {
      "from_screen_id": "CH01_MAP",
      "to_screen_id": "CH01_EVENT",
      "trigger": "select_node",
      "conditions": [
        "node.has_event=true"
      ],
      "notes": "노드별 대표 이벤트 오픈"
    },
    {
      "from_screen_id": "CH01_EVENT",
      "to_screen_id": "CH01_LOOT",
      "trigger": "choice_resolved",
      "conditions": [
        "event.grants_loot=true"
      ],
      "notes": "루팅 테이블이 붙은 선택지"
    },
    {
      "from_screen_id": "CH01_EVENT",
      "to_screen_id": "CH01_MAP",
      "trigger": "choice_resolved",
      "conditions": [
        "event.complete=true",
        "event.grants_loot=false"
      ],
      "notes": "일반 선택 종료"
    },
    {
      "from_screen_id": "CH01_LOOT",
      "to_screen_id": "CH01_MAP",
      "trigger": "loot_closed",
      "conditions": [],
      "notes": "루팅 종료 후 노드 맵 복귀"
    },
    {
      "from_screen_id": "CH01_EVENT",
      "to_screen_id": "CH01_BOSS_INTRO",
      "trigger": "event_id=EV_CH01_BOSS_BROADCAST",
      "conditions": [],
      "notes": "보스 직전 연출"
    },
    {
      "from_screen_id": "CH01_BOSS_INTRO",
      "to_screen_id": "CH01_COMBAT",
      "trigger": "enter_boss",
      "conditions": [],
      "notes": "보스전 시작"
    },
    {
      "from_screen_id": "CH01_COMBAT",
      "to_screen_id": "CH01_RESULT",
      "trigger": "combat_victory",
      "conditions": [
        "flag:chapter_01_escape_ready"
      ],
      "notes": "탈출 이벤트 후 결과 정산"
    },
    {
      "from_screen_id": "CH01_COMBAT",
      "to_screen_id": "CH01_MAP",
      "trigger": "combat_defeat_survive",
      "conditions": [],
      "notes": "패배 후 맵 복귀 또는 회복"
    },
    {
      "from_screen_id": "CH01_MAP",
      "to_screen_id": "CH01_RESULT",
      "trigger": "event_id=EV_CH01_EXTRACTION",
      "conditions": [
        "flag:chapter_01_completed"
      ],
      "notes": "챕터 종료"
    }
  ],
  "notes": [
    "CH01은 튜토리얼이므로 인벤토리, 소음, 오염 UI를 강제 노출한다.",
    "보스전 이전엔 지도 줌을 잠시 잠가 연출 집중도를 높인다."
  ]
}