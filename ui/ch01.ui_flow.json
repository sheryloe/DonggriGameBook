{
  "version": "1.0.0",
  "game_id": "dokdo_arc_webgame",
  "chapter_id": "CH01",
  "title": "잿빛 개장 UI 플로우",
  "entry_screen_id": "CH01_BRIEF",
  "screens": [
    {
      "screen_id": "CH01_BRIEF",
      "screen_type": "chapter_briefing",
      "title": "브리핑",
      "purpose": "챕터 목표와 시작 장비를 노출한다.",
      "widgets": [
        "objective_panel",
        "party_loadout",
        "dialogue_box"
      ],
      "data_sources": [
        "chapter_meta",
        "player_inventory",
        "npc_yoon_haein"
      ],
      "primary_actions": [
        "start_mission"
      ],
      "notes": [
        "튜토리얼 플래그를 여기서 세팅"
      ]
    },
    {
      "screen_id": "CH01_MAP",
      "screen_type": "world_map",
      "title": "여의도 지도",
      "purpose": "노드 접근과 이동 비용을 보여준다.",
      "widgets": [
        "node_map",
        "noise_meter",
        "contamination_meter",
        "route_hint"
      ],
      "data_sources": [
        "ch01.nodes",
        "player_stats"
      ],
      "primary_actions": [
        "select_node",
        "open_inventory",
        "open_status"
      ],
      "notes": [
        "튜토리얼이므로 비활성 기능을 UI에서 흐리게 처리"
      ]
    },
    {
      "screen_id": "CH01_EVENT",
      "screen_type": "event_dialogue",
      "title": "현장 이벤트",
      "purpose": "탐색/서사 이벤트를 처리한다.",
      "widgets": [
        "event_card",
        "choice_list",
        "npc_portrait"
      ],
      "data_sources": [
        "ch01.events",
        "player_flags",
        "player_items"
      ],
      "primary_actions": [
        "pick_choice",
        "back_to_map"
      ],
      "notes": [
        "텍스트는 2~3문단 이상 길어지지 않게 분절"
      ]
    },
    {
      "screen_id": "CH01_LOOT",
      "screen_type": "loot_resolution",
      "title": "루팅",
      "purpose": "루팅 결과와 인벤토리 압박을 처리한다.",
      "widgets": [
        "loot_grid",
        "capacity_meter",
        "compare_popup"
