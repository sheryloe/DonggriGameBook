/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-XSS-Protection: 1; mode=block
  Content-Security-Policy: default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com;

# Cache static assets aggressively
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache generated images
/generated/images/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
