{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.game/schemas/ui_flow.schema.json",
  "title": "Chapter UI Flow Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "game_id",
    "chapter_id",
    "title",
    "entry_screen_id",
    "screens",
    "transitions"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "game_id": {
      "type": "string"
    },
    "chapter_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "entry_screen_id": {
      "type": "string"
    },
    "screens": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/screen"
      }
    },
    "transitions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/transition"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "screen": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "screen_id",
        "screen_type",
        "title",
        "purpose",
        "widgets",
        "data_sources",
        "primary_actions"
      ],
      "properties": {
        "screen_id": {
          "type": "string"
        },
        "screen_type": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        },
        "widgets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "data_sources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "primary_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from_screen_id",
        "to_screen_id",
        "trigger",
        "conditions"
      ],
      "properties": {
        "from_screen_id": {
          "type": "string"
        },
        "to_screen_id": {
          "type": "string"
        },
        "trigger": {
          "type": "string"
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}