{
  "name": "donggrolgamebook",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "server"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "part1:enhance": "node scripts/generate-part1-enhancements.mjs",
    "content:generate:part2-4": "node scripts/generate-part2-4-content.mjs",
    "asset-prompts:generate": "node scripts/generate-asset-prompt-pack.mjs",
    "asset-prompts:generate:part1": "node scripts/generate-asset-prompt-pack.mjs --part P1",
    "asset-prompts:generate:part2": "node scripts/generate-asset-prompt-pack.mjs --part P2",
    "asset-prompts:generate:part3": "node scripts/generate-asset-prompt-pack.mjs --part P3",
    "asset-prompts:generate:part4": "node scripts/generate-asset-prompt-pack.mjs --part P4",
    "asset-prompts:item-icons": "node scripts/generate-stitch-item-icons.mjs",
    "assets:sync": "node scripts/sync-generated-assets.mjs",
    "assets:item-icons:crop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/crop-stitch-item-icons.ps1",
    "audio-prompts:boss": "node scripts/generate-boss-music-prompt-pack.mjs",
    "private:check": "node scripts/private-check.mjs",
    "private:export": "node scripts/private-export.mjs",
    "dashboard:media-sync": "node scripts/generate-media-sync-dashboard.mjs",
    "dashboard:media-catalog": "node scripts/generate-media-catalog-dashboard.mjs",
    "dashboard:modern": "node scripts/generate-modern-parts-dashboard.mjs",
    "openai-images:part1": "node scripts/generate-openai-part1-images.mjs",
    "tts:part1": "node scripts/generate-part1-tts.mjs",
    "tts:part1:mp3": "node scripts/generate-part1-tts-mp3.mjs",
    "tts:part1:hume:audition": "node scripts/generate-hume-part1-tts-audition.mjs",
    "tts:part1:elevenlabs:sync": "node scripts/sync-elevenlabs-v3-tts.mjs",
    "tts:part1:sync": "node scripts/sync-part1-tts-assets.mjs",
    "tts:part1:audit": "node scripts/audit-part1-tts-144.mjs",
    "tts:part1:regen-review": "node scripts/regenerate-part1-tts-openai-review.mjs",
    "vibevoice:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-vibevoice-local.ps1",
    "vibevoice:queue:part1": "node scripts/generate-vibevoice-part1-queue.mjs",
    "vibevoice:generate:part1": "node scripts/generate-vibevoice-part1.mjs",
    "vibevoice:sync:part1": "node scripts/sync-vibevoice-tts-assets.mjs",
    "vibevoice:audit:part1": "node scripts/audit-vibevoice-tts.mjs",
    "qa:part1": "node scripts/qa-part1-playtest.mjs",
    "qa:part1:flow": "node scripts/audit-part1-flow.mjs",
    "qa:part1:representative": "node scripts/qa-part1-representative.mjs",
    "openai:token-router": "node scripts/openai-token-router-status.mjs",
    "dev:part1": "vite --config apps/part1/vite.config.ts",
    "build:part1": "vite build --config apps/part1/vite.config.ts",
    "dev:part2": "vite --config apps/part2/vite.config.ts",
    "build:part2": "vite build --config apps/part2/vite.config.ts",
    "dev:part3": "vite --config apps/part3/vite.config.ts",
    "build:part3": "vite build --config apps/part3/vite.config.ts",
    "dev:part4": "vite --config apps/part4/vite.config.ts",
    "build:part4": "vite build --config apps/part4/vite.config.ts",
    "build:apps": "npm run build:part1 && npm run build:part2 && npm run build:part3 && npm run build:part4",
    "dev:server": "npm --prefix server run dev",
    "build:server": "npm --prefix server run build",
    "preview": "vite preview",
    "repo:audit-assets": "bash scripts/audit-assets.sh",
    "ops:csv-gate-sync": "node scripts/csv-gate-sync.mjs",
    "sim:agents": "node scripts/simulate_agents.mjs",
    "nano": "node scripts/gemini-nano.mjs",
    "nano:login": "node scripts/gemini-nano.mjs --login",
    "nano:logout": "node scripts/gemini-nano.mjs --logout",
    "qa:part1:long": "node scripts/qa-part1-long-route.mjs"
  },
  "dependencies": {
    "@apps-in-toss/web-framework": "^2.4.3",
    "ajv": "^8.18.0",
    "dotenv": "^17.2.3",
    "google-auth-library": "^10.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.8.7",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
